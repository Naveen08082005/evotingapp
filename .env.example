# ==============================================================================
# COLLEGE E-VOTING SYSTEM — ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to a new file named '.env' in the project root:
# CP .env.example .env (Windows) or cp .env.example .env (macOS/Linux)
#
# DO NOT COMMIT THE ACTUAL '.env' FILE TO VERSION CONTROL. It contains sensitive keys.
# Ensure that '.env' is added to your '.gitignore' file.
# ==============================================================================

# 1. SUPABASE CONNECTION CONFIGURATION
# ------------------------------------------------------------------------------
# The API URL of your Supabase project (e.g., https://xyzcompany.supabase.co)
# You can find this in: Supabase Dashboard -> Settings -> API -> Project URL
SUPABASE_URL=your_supabase_project_url_here

# The anonymous public API key of your Supabase project (anon public)
# This key is safe to distribute to client apps as long as Row-Level Security (RLS) is enabled.
# You can find this in: Supabase Dashboard -> Settings -> API -> Project API Keys -> anon public
SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# ==============================================================================
# SECURE USAGE & PROD DEPLOYMENT INSTRUCTIONS
# ==============================================================================
#
# 1. LOCAL DEVELOPMENT SETUP:
#    - Create a local '.env' file matching this template.
#    - Initialize these variables in your Dart entry point (`lib/main.dart` or service loaders) 
#      using a package like `flutter_dotenv` or compile-time environment defines.
#      Example using compile-time variables:
#      flutter run --dart-define=SUPABASE_URL=https://... --dart-define=SUPABASE_ANON_KEY=...
#
# 2. SOURCE CONTROL SECURITY:
#    - The '.env' file is listed in '.gitignore' to prevent leaks.
#    - Never push hardcoded Supabase keys to GitHub or GitLab.
#
# 3. PRODUCTION DEPLOYMENT & CI/CD PIPELINES:
#    - For Android/iOS release builds, pass these variables as dart-defines during compile-time:
#      flutter build apk --release --dart-define=SUPABASE_URL=$PROD_URL --dart-define=SUPABASE_ANON_KEY=$PROD_KEY
#    - In GitHub Actions or other CI runners, define these as repository Secrets (not Variables)
#      and inject them into the release command arguments dynamically.
#
# ==============================================================================
